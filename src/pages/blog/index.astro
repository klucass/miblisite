---
import Layout from "../../layouts/Layout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import BlogCTA from "../../components/BlogCTA.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

const posts = (await getCollection("blog")).sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout title="Blog | Miblify" description="Artigos sobre vendas digitais, marketing e novidades da Miblify.">
  <div class="flex flex-col min-h-screen">
    <Header isBlog={true} />
    <main class="max-w-6xl mx-auto px-6 py-20 md:py-32 grow w-full">
      <header class="mb-16 md:mb-24 text-center">
        <h1 class="text-4xl md:text-6xl font-bold text-[#1A1A1A] mb-6 font-cabinet-bold">Blog Miblify</h1>
        <p class="text-lg md:text-xl text-gray-600 max-w-2xl mx-auto leading-relaxed">
          Conteúdo especializado para quem quer escalar suas vendas de produtos digitais com simplicidade.
        </p>
      </header>

      <div class="mt-10 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-10">
        {
          posts.map((post) => (
            <a
              href={`/blog/${post.id}/`}
              class="group block bg-white rounded-md border-2 border-[#1A1A1A] overflow-hidden transition-all blog-card">
              {post.data.heroImage && (
                <div class="aspect-video overflow-hidden border-b-2 border-[#1A1A1A]">
                  <Image
                    src={post.data.heroImage}
                    alt=""
                    class="w-full h-full object-cover transition-transform group-hover:scale-105"
                  />
                </div>
              )}
              <div class="p-8">
                <h2 class="text-2xl font-bold text-[#1A1A1A] mb-3 group-hover:text-[#3B38E8] transition-colors font-cabinet-bold leading-snug">
                  {post.data.title}
                </h2>
                <p class="text-gray-600 line-clamp-2 leading-relaxed text-base">{post.data.description}</p>
              </div>
            </a>
          ))
        }
      </div>

      {
        posts.length === 0 && (
          <div class="text-center py-20 bg-gray-50 rounded-3xl">
            <p class="text-gray-500 text-lg">Em breve teremos nossos primeiros artigos por aqui!</p>
          </div>
        )
      }
    </main>
    <BlogCTA />
    <Footer />
  </div>
</Layout>

<style>
  .blog-card {
    box-shadow: 4px 4px 0 0 oklch(0.235 0 129.63);
    transform: translate(0, 0);
  }
  .blog-card:hover {
    transform: translate(-2px, -2px);
    box-shadow: 6px 6px 0 0 oklch(0.235 0 129.63);
  }
  .blog-card:active {
    transform: translate(2px, 2px);
    box-shadow: 2px 2px 0 0 oklch(0.235 0 129.63);
  }
</style>
