---
import { Icon } from '@astrojs/starlight/components';

interface Props {
	title: string;
	icon?: string;
}

const { title, icon } = Astro.props;
---

<article class="card sl-flex">
	<p class="title sl-flex">
		<slot name="icon">
			{icon && <Icon name={icon as any} class="icon" />}
		</slot>
		<span set:html={title} />
	</p>
	<div class="body">
		<slot />
	</div>
</article>

<style>
	.card {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
		padding: clamp(1rem, calc(0.125rem + 3vw), 2rem);
	}
	.title {
		font-weight: 600;
		font-size: var(--sl-text-h4);
		color: var(--sl-color-white);
		line-height: var(--sl-line-height-headings);
		display: flex;
		gap: 0.75rem;
		align-items: center;
	}
	:global(.card .icon) {
		color: var(--sl-color-accent-high);
		width: 1.5rem !important;
		height: 1.5rem !important;
		flex-shrink: 0;
	}
	.card .body {
		margin: 0;
		font-size: clamp(var(--sl-text-sm), calc(0.5rem + 1vw), var(--sl-text-body));
	}
</style>
