---
import { Image } from 'astro:assets';
import miblifyCouch from '../../assets/img/miblify-couch.png';

interface Props {
	tagline: string;
	actions: Array<{
		text: string;
		link: string;
		icon?: string;
		variant?: 'primary' | 'secondary' | 'minimal';
	}>;
}

const { tagline, actions } = Astro.props;
---

<div class="custom-hero sl-flex">
	<div class="content sl-flex">
		<p class="tagline">{tagline}</p>
		<div class="actions sl-flex">
			{actions.map(({ text, link, icon, variant }) => (
				<a href={link} class={`action ${variant || 'secondary'}`}>
					{text}
				</a>
			))}
		</div>
	</div>
	<div class="image-container">
		<Image src={miblifyCouch} alt="Miblify Couch" width={800} quality="max" class="hero-img" />
	</div>
</div>

<style>
	.custom-hero {
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 2rem;
		padding: 3rem 1rem;
		background-color: oklch(0.92 0.04 277);
		border-radius: 0.5rem;
	}

	@media (min-width: 50rem) {
		.custom-hero {
			flex-direction: row;
			text-align: left;
			justify-content: space-between;
			padding: 4rem 2rem;
		}
		.content {
			align-items: flex-start;
			max-width: 30rem;
		}
	}

	.content {
		flex-direction: column;
		width: 100%;
	}

	.tagline {
		font-size: clamp(var(--sl-text-lg), calc(0.5rem + 1.5vw), var(--sl-text-xl));
		line-height: var(--sl-line-height-headings);
		max-width: 40ch;
		margin-bottom: 2rem;
		color: var(--sl-color-gray-2);
	}

	.actions {
		gap: 1rem;
		flex-wrap: wrap;
		justify-content: center;
		width: 100%;
	}

	@media (min-width: 50rem) {
		.actions {
			justify-content: flex-start;
		}
	}

	.action {
		display: inline-block;
		padding: 0.75rem 1.5rem;
		border-radius: 9999px;
		font-weight: 600;
		text-decoration: none;
		transition: all 0.2s ease;
		white-space: nowrap;
	}

	.action.primary {
		background-color: var(--sl-color-accent);
		color: white;
	}

	.action.primary:hover {
		background-color: var(--sl-color-accent-high);
		transform: translateY(-1px);
	}

	.action.secondary, .action.minimal {
		color: var(--sl-color-gray-2);
		border: 1px solid var(--sl-color-gray-5);
	}

	.action.secondary:hover, .action.minimal:hover {
		color: var(--sl-color-accent);
		border-color: var(--sl-color-accent);
	}

	.image-container {
		width: 100%;
		max-width: 35rem;
	}

	.hero-img {
		width: 100%;
		height: auto;
		object-fit: contain;
		image-rendering: -webkit-optimize-contrast;
	}
</style>
