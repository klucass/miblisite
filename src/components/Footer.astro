---
import { Image } from "astro:assets";
import LogoVertical from "../assets/img/miblify_vertical_plataforma.svg";
import InstagramLogo from "phosphor-astro/InstagramLogo.astro";
import TwitterLogo from "phosphor-astro/TwitterLogo.astro";
---

<footer class="bg-base-content text-base-200">
  <div class="max-w-6xl mx-auto reveal md:flex md:justify-between py-20 px-6">
    <div>
      <Image src={LogoVertical} alt="Miblify" class="p-0 w-full md:w-[350px]" />
    </div>
    <div class="grid grid-cols-1 gap-12 md:grid-cols-3 md:gap-16 lg:gap-24 [&_li]:my-2 [&_li]:text-base-100/50 [&_li>a]:link-hover mt-12 md:mt-0">
      <div>
        <p class="font-bold mb-5">Termos legais</p>
        <ul>
          <li>
            <a href="/use">Termos de uso</a>
          </li>
          <li>
            <a href="/privacy">Política de privacidade</a>
          </li>
          <li>
            <a href="/notallowed">Produtos não permitidos</a>
          </li>
        </ul>
      </div>
      <div>
        <p class="font-bold mb-5">Saiba mais</p>
        <ul>
          <li>
            <a href="/manifest">Manifesto</a>
          </li>
          <li>
            <a href="/blog/">Blog</a>
          </li>
          <li>
            <a href="/about">Sobre nós</a>
          </li>
          <li>
            <a href="/help/">Central de Ajuda</a>
          </li>
        </ul>
      </div>
      <div>
        <p class="font-bold mb-5">Redes sociais</p>
        <div class="flex gap-4">
          <a
            href="https://www.instagram.com/miblify"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-all hover:-translate-y-0.5 active:translate-y-0"
            aria-label="Instagram">
            <InstagramLogo class="size-7" />
          </a>
          <a
            href="https://twitter.com/miblify"
            target="_blank"
            rel="noopener noreferrer"
            class="hover:text-primary transition-all hover:-translate-y-0.5 active:translate-y-0"
            aria-label="Twitter">
            <TwitterLogo class="size-7" />
          </a>
        </div>
      </div>
    </div>
  </div>
</footer>
