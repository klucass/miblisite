---
import Layout from "./Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BlogCTA from "../components/BlogCTA.astro";
import { Image } from "astro:assets";
import Calendar from "phosphor-astro/CalendarDuotone.astro";

interface Props {
  title: string;
  description?: string;
  pubDate?: Date;
  heroImage?: any;
}

const { title, description, pubDate, heroImage } = Astro.props;

// Normaliza a URL da imagem para o Layout (Open Graph)
const ogImage = heroImage
  ? typeof heroImage === "string"
    ? heroImage.startsWith("http")
      ? heroImage
      : new URL(heroImage, Astro.site || "https://www.miblify.com").toString()
    : new URL(heroImage.src, Astro.site || "https://www.miblify.com").toString()
  : undefined;
---

<Layout title={`${title} | Blog Miblify`} description={description} image={ogImage}>
  <div class="flex flex-col min-h-screen">
    <Header isBlog={true} />
    <main class="max-w-4xl mx-auto px-6 pt-20 md:py-12 grow w-full">
      <article class="prose prose-lg prose-slate max-w-none">
        {
          heroImage && (
            <Image src={heroImage} alt="" class="w-full h-auto rounded-sm mb-6 shadow-sm border-2 border-[#1A1A1A]" />
          )
        }
        <div class="md:py-6">
          <h1 class="text-4xl md:text-6xl font-bold text-[#3B38E8] mb-8 font-cabinet-bold leading-tight tracking-tight">
            {title}
          </h1>
          {
            pubDate && (
              <div class="blog-meta">
                <Calendar weight="duotone" class="blog-meta-icon size-8" />
                <time dateTime={pubDate.toISOString()}>
                  {pubDate.toLocaleDateString("pt-BR", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            )
          }
        </div>
        <div class="blog-content">
          <slot />
        </div>
      </article>
    </main>
    <BlogCTA />
    <Footer />
  </div>
</Layout>

<style is:global>
  .blog-content {
    color: #333;
    line-height: 1.8;
    font-size: 1.25rem;
  }

  /* Data de publicação — discreta e elegante */
  .blog-meta {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: -0.5rem;
    margin-bottom: 2rem;
  }

  .blog-meta-icon {
    color: #999;
    flex-shrink: 0;
  }

  .blog-meta time {
    font-family: "cabinet", sans-serif;
    color: #666;
    font-size: 0.95rem;
    font-weight: 500;
    text-transform: capitalize;
    letter-spacing: 0.3px;
    transition: color 0.3s ease;
  }

  .blog-meta time:hover {
    color: #3b38e8;
  }

  /* Seleção de texto — divertida com cores da marca */
  .blog-content ::selection {
    background: oklch(77.74% 0.2001 333.22);
    color: white;
    text-shadow: 0 1px 2px rgba(0, 0, 0, 0.1);
  }

  .blog-content a {
    color: #3b38e8;
    text-decoration: underline;
    text-underline-offset: 4px;
    font-weight: 600;
    transition: all 0.2s ease;
  }
  .blog-content a:hover {
    color: #1a1a1a;
    text-decoration-thickness: 2px;
  }

  /* H2 — Roxo (Primary), grande e impactante */
  .blog-content h2 {
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: #3b38e8;
    margin-top: 4rem;
    margin-bottom: 1.5rem;
    font-size: 2.5rem;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.3px;
  }

  /* H3 — Rosa (Secondary), substítulo elegante */
  .blog-content h3 {
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: #333;
    margin-top: 3rem;
    margin-bottom: 1.2rem;
    font-size: 1.875rem;
    line-height: 1.3;
    font-weight: 700;
    letter-spacing: -0.3px;
  }

  /* H4 — Amarelo (Accent), destaque sutil */
  .blog-content h4 {
    font-family: ui-sans-serif, system-ui, sans-serif;
    color: #1a1a1a;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    font-size: 1.5rem;
    line-height: 1.3;
    font-weight: 600;

    display: inline-block;
    padding: 0.5rem 1rem;
  }

  .blog-content p {
    margin-bottom: 1.5rem;
  }

  .blog-content ul {
    list-style-type: none;
    padding-left: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .blog-content li {
    margin-bottom: 0.75rem;
    position: relative;
    padding-left: 1.5rem;
  }
</style>
